# ── GrowthifyEdge OS — environment template ─────────────────────────────────
# Copy this file to ".env" and fill in your own values. NEVER commit ".env".
#
# Supabase setup (free tier):
#   1. Create a project at https://supabase.com
#   2. Run supabase/schema.sql in the SQL editor (tables, RLS, triggers)
#   3. Create a PRIVATE Storage bucket named "media"
#   4. Paste your Project URL + anon (publishable) key below
#
# Leave these blank to run in LOCAL mode (browser IndexedDB, no login) — handy
# for offline use or a quick demo with zero setup.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# "supabase" (default when keys are present) or "local"
VITE_DATA_SOURCE=
